# Flexar Zulip Docker build context excludes.
# Keep the build context minimal — Zulip source itself is ~250MB, .git is 1GB+.

.git
.github

# Node/Python build artifacts
node_modules
**/__pycache__
*.pyc
.venv
.tox/
.pytest_cache

# Zulip-specific build artifacts
var/
zulip-py3-venv/
static/min/
static/webpack-bundles/
prod-static/
build/
dist/
# NOTE: do NOT exclude static/generated/ or web/generated/ — they're tracked
# placeholder directories that tools/setup/emoji/build_emoji uses as
# symlink targets at provision time. Excluding them causes os.symlink to
# fail with ENOENT (missing parent dir).

# IDE / editor
.idea
.vscode
*.swp
.DS_Store

# Local env files (must NOT leak into image)
flexar/deploy/.env
flexar/deploy/.env.local
.env.local

# Misc
*.log
*.tar.gz
zulip-server-docker.tar.gz
