# Flexar Zulip — environment template.
# Copy to .env, fill in real values, then `docker compose --env-file .env up -d`.
# The actual production .env lives on the server at /home/deploy/zulip.env
# and is NEVER committed to git.

# ============================================================
# Compose project + image
# ============================================================
COMPOSE_PROJECT_NAME=flexar-zulip

# Pulled by deploy_zulip.sh. For local dev: leave commented to use build.
# ZULIP_IMAGE=cr.yandex/REGISTRY_ID/flexar-zulip-server:latest

# ============================================================
# Network — external ports on the host
# ============================================================
ZULIP_HTTP_PORT=8800
ZULIP_HTTPS_PORT=8843

# Public-facing hostname:port. Used in invitation emails, CSRF, etc.
# For IP-only access (no DNS): "95.84.162.15:8843"
# With a domain: "flexar-hub.example.com"
ZULIP_EXTERNAL_HOST=95.84.162.15:8843

# ============================================================
# Secrets (generate via `openssl rand -base64 32` for each)
# ============================================================
ZULIP__POSTGRES_PASSWORD=CHANGE_ME_postgres_password
ZULIP__MEMCACHED_PASSWORD=CHANGE_ME_memcached_password
ZULIP__RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password
ZULIP__REDIS_PASSWORD=CHANGE_ME_redis_password
ZULIP__SECRET_KEY=CHANGE_ME_64_byte_django_secret_key

# Email password for outgoing SMTP (used for invite/notify mail). Optional.
ZULIP__EMAIL_PASSWORD=

# ============================================================
# Admin / branding
# ============================================================
ZULIP_ADMIN_EMAIL=admin@flexar.local

# ============================================================
# Email (SMTP) for outgoing mail. Required for user invites to work.
# Empty values disable outgoing mail (server logs invite URLs instead).
# ============================================================
SETTING_EMAIL_HOST=
SETTING_EMAIL_HOST_USER=
SETTING_EMAIL_PORT=587
SETTING_EMAIL_USE_TLS=True
SETTING_NOREPLY_EMAIL_ADDRESS=noreply@flexar.local

# ============================================================
# Auth backends. Comma-separated. EmailAuthBackend = email+password.
# For Yandex OAuth (matches main Flexar): add YandexAuthBackend later,
# requires SETTING_SOCIAL_AUTH_YANDEX_OAUTH2_KEY/SECRET.
# ============================================================
ZULIP_AUTH_BACKENDS=EmailAuthBackend

# ============================================================
# TLS certificates.
#   self-signed  — generate on first boot (good for IP-based test)
#   mounted      — bind-mount real certs into /etc/letsencrypt
# ============================================================
CERTIFICATES=self-signed

# ============================================================
# Reverse-proxy hints (leave default for direct IP:port access)
# ============================================================
LOADBALANCER_IPS=
TRUST_GATEWAY_IP=false

# ============================================================
# Tuning
# ============================================================
NGINX_WORKERS=2
AUTO_BACKUP_ENABLED=false
